/* pages/chatList/index.wxss */

.page-wrap {
  min-height: 100vh;
  background-color: #f0f2f5;
}

.chat-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f5f5f5;
}

.chat-item:active {
  background-color: #f9fafb;
}

.chat-goods-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background-color: #eee;
}

.chat-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.chat-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.chat-last {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.chat-meta {
  flex-shrink: 0;
  margin-left: 16rpx;
  text-align: right;
}

.chat-time {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

.chat-unread {
  margin-top: 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background-color: #c44536;
  padding: 0 8rpx;
}

.unread-num {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 300rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #6b7280;
}

.empty-sub {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 16rpx;
}
