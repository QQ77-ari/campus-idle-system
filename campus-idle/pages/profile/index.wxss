/* pages/profile/index.wxss */

.page-wrap {
  min-height: 100vh;
  background-color: #f0f2f5;
}

/* ========== 用户信息头部 ========== */
.user-header {
  position: relative;
  padding-top: 1rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #2d6a4f 0%, #40916c 50%, #52b788 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 80rpx 40rpx 50rpx;
}

/* ========== 未登录状态 ========== */
.login-area {
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: normal;
  flex-shrink: 0;
}

.avatar-wrapper::after {
  border: none;
}

.login-info {
  margin-left: 24rpx;
}

.nickname-input {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  min-width: 280rpx;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.login-hint {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 10rpx;
}

/* ========== 已登录状态 ========== */
.user-area {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  background-color: #eee;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.user-info {
  margin-left: 30rpx;
}

.user-name {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
}

.user-school {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* ========== 数据统计卡片 ========== */
.stats-card {
  display: flex;
  background-color: #fff;
  margin: -20rpx 30rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #2d6a4f;
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  background-color: #f0f0f0;
  margin: 24rpx 0;
}

/* ========== 菜单列表 ========== */
.menu-section {
  background-color: #fff;
  margin: 0 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f9fafb;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-icon-fav {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
}

.menu-icon-fav::after {
  content: '❤';
  font-size: 24rpx;
}

.menu-icon-publish {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.menu-icon-publish::after {
  content: ' ';
  font-size: 24rpx;
}

.menu-icon-privacy {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}

.menu-icon-privacy::after {
  content: ' ';
  font-size: 24rpx;
}

.menu-icon-admin {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.menu-icon-admin::after {
  content: ' ';
  font-size: 24rpx;
}

.menu-icon-about {
  background: linear-gradient(135deg, #a8e6cf, #3dc1d3);
}

.menu-icon-about::after {
  content: 'ℹ';
  font-size: 24rpx;
}

.menu-icon-ai {
  background: linear-gradient(135deg, #2d6a4f, #40916c);
}

.menu-icon-ai::after {
  content: ' ';
  font-size: 24rpx;
}

.menu-icon-chat {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.menu-icon-chat::after {
  content: '✉';
  font-size: 24rpx;
}

.menu-icon-order {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.menu-icon-order::after {
  content: ' ';
  font-size: 24rpx;
}

.menu-icon-reset {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.menu-icon-reset::after {
  content: '↻';
  font-size: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a2e;
  font-weight: 500;
}

.menu-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  font-weight: 300;
}

/* ========== 版本信息 ========== */
.version-info {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.version-text {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

.version-sub {
  display: block;
  font-size: 22rpx;
  color: #d1d5db;
  margin-top: 8rpx;
}
