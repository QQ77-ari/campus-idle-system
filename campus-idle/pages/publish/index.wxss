/* pages/publish/index.wxss（商务大气版） */

.page-wrap {
  padding: 30rpx;
  padding-bottom: 100rpx;
}

/* ========== 通用段落区块 ========== */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-header .section-label {
  margin-bottom: 0;
}

.ai-gen-btn {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #2d6a4f, #40916c);
  border-radius: 20rpx;
}

.ai-gen-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

/* ========== 图片上传区 ========== */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 156rpx;
  height: 156rpx;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  display: block;
}

.image-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-text {
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
}

.image-add {
  width: 156rpx;
  height: 156rpx;
  border: 2rpx dashed #d1d5db;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f9fafb;
}

.add-icon {
  font-size: 48rpx;
  color: #9ca3af;
  line-height: 1;
}

.add-text {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

/* ========== 输入框 ========== */
.form-input {
  font-size: 28rpx;
  color: #1a1a2e;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

/* ========== 选择器 ========== */
.form-picker {
  font-size: 28rpx;
  color: #1a1a2e;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-picker.placeholder {
  color: #bbb;
}

/* ========== 文本域 ========== */
.form-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.6;
  padding: 16rpx 0;
  box-sizing: border-box;
}

/* ========== 字数统计 ========== */
.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #d1d5db;
  margin-top: 8rpx;
}

/* ========== 联系方式 ========== */
.contact-section {
  border: 2rpx solid rgba(45, 106, 79, 0.15);
}

.contact-fields {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.contact-field {
  display: flex;
  align-items: center;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.contact-input {
  flex: 1;
  border-bottom: none !important;
  padding: 20rpx 0;
  font-size: 26rpx;
}

/* ========== 提交按钮 ========== */
.submit-area {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #2d6a4f, #40916c);
  border-radius: 46rpx;
  border: none;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(45, 106, 79, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: linear-gradient(135deg, #a8dba8, #c8e6c9);
  box-shadow: none;
}
