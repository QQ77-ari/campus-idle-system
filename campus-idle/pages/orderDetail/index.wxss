/* pages/orderDetail/index.wxss */

.page-wrap {
  min-height: 100vh;
  background-color: #f0f2f5;
  padding-bottom: 40rpx;
}

.status-card {
  background: linear-gradient(135deg, #2d6a4f, #40916c);
  padding: 40rpx 32rpx;
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
}

.status-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.info-section, .review-section {
  background-color: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #2d6a4f;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child { border-bottom: none; }

.info-label {
  font-size: 26rpx;
  color: #6b7280;
}

.info-value {
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: 500;
}

.info-value.price {
  color: #c44536;
  font-weight: 700;
  font-size: 30rpx;
}

.rating-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.rating-label {
  font-size: 26rpx;
  color: #6b7280;
}

.rating-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 44rpx;
  color: #d1d5db;
}

.star.active { color: #f59e0b; }

.review-input {
  width: 100%;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.review-submit {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #2d6a4f, #40916c);
  border-radius: 40rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.action-section {
  display: flex;
  gap: 20rpx;
  margin: 30rpx 24rpx;
}

.action-btn {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.confirm-btn {
  background: linear-gradient(135deg, #2d6a4f, #40916c);
  color: #fff;
}

.cancel-btn {
  background: #fff;
  border: 2rpx solid #e5e7eb;
  color: #6b7280;
}
