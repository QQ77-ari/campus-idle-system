/* pages/favorites/index.wxss（商务大气版） */

.page-wrap {
  min-height: 100vh;
  padding: 20rpx;
  background-color: #f0f2f5;
}

/* ========== 收藏列表 ========== */
.collect-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 单条收藏卡片 */
.collect-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
}

.collect-card:active {
  transform: scale(0.98);
}

/* 商品缩略图 */
.collect-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

/* 商品文字信息 */
.collect-info {
  flex: 1;
  margin: 0 20rpx;
  overflow: hidden;
}

.collect-title {
  display: block;
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-weight: 500;
}

.collect-price {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #c44536;
  margin-top: 16rpx;
}

/* 取消收藏按钮 */
.collect-remove {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 24rpx;
}

.remove-text {
  font-size: 22rpx;
  color: #6b7280;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 300rpx 0 0;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-top: 20rpx;
  font-weight: 500;
}

.empty-sub {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 12rpx;
}
