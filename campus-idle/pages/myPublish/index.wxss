/* pages/myPublish/index.wxss（商务大气版） */

.page-wrap {
  min-height: 100vh;
  padding: 20rpx;
  background-color: #f0f2f5;
}

/* ========== 列表 ========== */
.publish-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 单条卡片 */
.publish-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
}

.publish-card:active {
  transform: scale(0.98);
}

/* 商品缩略图 */
.publish-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

/* 商品文字信息 */
.publish-info {
  flex: 1;
  margin: 0 20rpx;
  overflow: hidden;
}

.publish-title {
  display: block;
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-weight: 500;
}

.publish-price {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #c44536;
  margin-top: 12rpx;
}

.publish-status {
  margin-top: 10rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.status-tag.on-sale {
  color: #2d6a4f;
  background-color: rgba(45, 106, 79, 0.08);
}

.status-tag.sold {
  color: #9ca3af;
  background-color: #f0f0f0;
}

/* 操作按钮区 */
.publish-actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 12rpx;
}

.publish-btn {
  padding: 10rpx 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 24rpx;
  text-align: center;
}

.btn-text {
  font-size: 22rpx;
  color: #6b7280;
}

.btn-danger {
  border-color: #fca5a5;
}

.btn-danger .btn-text {
  color: #ef4444;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 300rpx 0 0;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-top: 20rpx;
  font-weight: 500;
}

.empty-sub {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 12rpx;
}
