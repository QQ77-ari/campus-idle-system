/* pages/admin/index.wxss */

.page-wrap {
  min-height: 100vh;
  background-color: #f0f2f5;
  padding: 20rpx 24rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  width: calc(50% - 8rpx);
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.stat-card.warn {
  border-left: 6rpx solid #c44536;
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #2d6a4f;
}

.stat-card.warn .stat-num { color: #c44536; }

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #2d6a4f;
}

.empty-mini {
  text-align: center;
  padding: 30rpx 0;
  color: #9ca3af;
  font-size: 26rpx;
}

/* 举报项 */
.report-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.report-item:last-child { border-bottom: none; }

.report-info { flex: 1; overflow: hidden; }

.report-title {
  display: block;
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: 500;
}

.report-reason {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

.report-time {
  display: block;
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.report-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.report-btn {
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.btn-handle { background: #d1fae5; color: #059669; }
.btn-dismiss { background: #f3f4f6; color: #6b7280; }

.report-status {
  font-size: 22rpx;
  color: #9ca3af;
  flex-shrink: 0;
}

/* 商品管理项 */
.goods-admin-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-admin-item:last-child { border-bottom: none; }

.goods-admin-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #eee;
}

.goods-admin-info {
  flex: 1;
  margin-left: 16rpx;
  overflow: hidden;
}

.goods-admin-title {
  display: block;
  font-size: 26rpx;
  color: #1a1a2e;
}

.goods-admin-price {
  display: block;
  font-size: 24rpx;
  color: #c44536;
  font-weight: 600;
  margin-top: 4rpx;
}

.goods-admin-status {
  font-size: 20rpx;
  color: #9ca3af;
}

.goods-admin-status.on-sale { color: #059669; }

.goods-admin-action {
  padding: 10rpx 20rpx;
  border: 2rpx solid #fecaca;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #dc2626;
  flex-shrink: 0;
  margin-left: 16rpx;
}
