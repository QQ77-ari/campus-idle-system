/* pages/privacy/index.wxss */

.page-wrap {
  min-height: 100vh;
  background-color: #f0f2f5;
  padding: 24rpx;
  padding-bottom: 180rpx;
}

.privacy-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.privacy-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 12rpx;
}

.privacy-update {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  text-align: center;
  margin-bottom: 36rpx;
}

.privacy-section {
  margin-bottom: 32rpx;
}

.section-heading {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2d6a4f;
  margin-bottom: 16rpx;
}

.section-content {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.section-item {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  padding-left: 8rpx;
}

/* ========== 底部同意按钮 ========== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.agree-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #2d6a4f, #40916c);
  border-radius: 44rpx;
  border: none;
  letter-spacing: 4rpx;
}

.agree-btn::after {
  border: none;
}
