<!--pages/orders/index.wxml-->
<!-- 我的订单页 -->

<view class="page-wrap">
  <!-- 选项卡 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'buy' ? 'active' : ''}}" data-tab="buy" bindtap="onTabChange">
      <text>我买到的</text>
    </view>
    <view class="tab-item {{activeTab === 'sell' ? 'active' : ''}}" data-tab="sell" bindtap="onTabChange">
      <text>我卖出的</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view
      class="order-card"
      wx:for="{{activeTab === 'buy' ? buyOrders : sellOrders}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="onOrderTap"
    >
      <image
        class="order-img"
        src="{{item.goodsImage || '/images/goods-placeholder.png'}}"
        mode="aspectFill"
        binderror="onImageError"
        data-index="{{index}}"
      />
      <view class="order-info">
        <text class="order-title ellipsis">{{item.goodsTitle}}</text>
        <text class="order-price">¥{{item.price}}</text>
        <view class="order-status status-{{item.status}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{isEmpty}}" class="empty-state">
    <text class="empty-icon"> </text>
    <text class="empty-text">暂无订单</text>
  </view>
</view>
